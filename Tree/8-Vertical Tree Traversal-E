/*
Definition for Node
class Node {
  public:
    int data;
    Node* left;
    Node* right;

    Node(int val) {
        data = val;
        left = right = nullptr;
    }
};
*/

class Solution {
  public:
    vector<vector<int>> verticalOrder(Node *root) {
        // code here
        
        if(root == nullptr)return {};
        
        vector<vector<int>> ans;
        
        // using map for horizontal sorting and storing all the values 
        map<int , vector<int> > mp ;
        
        // queue stores node and horizontal dist 
        queue<pair<Node * ,int > > qu;
        
        qu.push(make_pair(root, 0));
        
        while(qu.empty() == false){
            
           pair<Node * ,int > t = qu.front();
            qu.pop();
            
            Node * temp = t.first;
            int hd = t.second ; 
            
            
            mp[hd].push_back(temp->data);
            
            if(temp->left){
                qu.push(make_pair(temp->left , hd -1 ));
                
            }
            if(temp ->right){
                qu.push(make_pair(temp->right , hd + 1));

            }
            
            
        }
        
        
        for(auto i : mp){
            ans.push_back(i.second);
        }
        
        
        
        return ans;
    }
};