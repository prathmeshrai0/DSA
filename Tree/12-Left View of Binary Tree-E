class Solution {
	public:
	void recursiveSolution(Node * root, vector<int> & ans, int level = 0) {
		if (!root)return;
		
		if (level == ans.size()) {
			
			ans.push_back(root->data);
		}
		recursiveSolution(root->left, ans, level + 1);
		recursiveSolution(root->right, ans, level + 1);
		
	}
	vector<int> leftView(Node *root) {
		
		if (!root)return {};
		
		vector<int> ans;
		
		recursiveSolution(root, ans, 0);
		
		return ans;
		
	}
};