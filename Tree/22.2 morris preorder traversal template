
void morrisInorder(BinaryTreeNode<int>* root){

    while (root){
        if(root->left == nullptr){
            // action 
            root = root->right;
        }
        else {
            BinaryTreeNode<int>* prev = root->left ;

            while(prev ->right && prev ->right != root){
                prev = prev ->right;
            }

            if(prev->right == nullptr){
                // action

                // linking
                prev->right = root;
                root = root->left;
            }
            else{
                // prev->right == root
                
                prev->right = nullptr;
                root = root->right;

            }
        }
    }
}