https://www.geeksforgeeks.org/problems/boundary-traversal-of-binary-tree/1



/*
Definition for Node
class Node {
  public:
    int data;
    Node* left;
    Node* right;

    Node(int val) {
        data = val;
        left = right = nullptr;
    }
};
*/

class Solution {
  public:
    void traverseLeft(Node * root , vector<int> &left){
        if(!root || (!root->left && !root->right))return;
        
        left.push_back(root->data);
        
        if(root->left)traverseLeft(root->left,left);
        else traverseLeft(root->right,left);
        
    }
    void traverseLeaf(Node * root , vector<int> &leaf){
        if(!root)return;
        if(!root->left && !root->right)leaf.push_back(root->data);
        traverseLeaf(root->left , leaf); 
        traverseLeaf(root->right , leaf); 
    }
    void traverseRight(Node * root , vector<int> &right){
        if(!root || (!root->left && !root->right))return;
        
        
        if(root->right)
            traverseRight(root->right ,right);
        else traverseRight(root->left ,right);
        
        right.push_back(root->data);
    }
    
    vector<int> boundaryTraversal(Node *root) {
        if(!root)return {};
        
        vector<int> ans;
        
        ans.push_back(root->data);
        
        traverseLeft(root->left ,ans); 
        traverseLeaf(root->left,ans);
        traverseLeaf(root->right,ans);
        traverseRight(root->right,ans); 
        
        
        
        return  ans;
        
    }
};