/*
Definition for Node
class Node {
public:
    int data;
    Node* left;
    Node* right;

    Node(int val) {
        data = val;
        left = right = nullptr;
    }
};
*/

class Solution {
  public:
    int height(Node* root) {
       
        if(root == NULL){
            return -1;
        }
        
        int leftCount ; 
        leftCount  = height(root->left);
        
        
        int rightCount ; 
        rightCount  = height(root->right);
      
        
        int count = max(leftCount , rightCount) + 1;
        
        return count;
        
    }
};
